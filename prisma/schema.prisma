generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  EDITOR
  VENDEDOR
  CLIENTE
}

enum ProductStatus {
  PUBLISHED
  DRAFT
  UNPUBLISHED
}

enum ShippingMode {
  FIXED
  FREE
}

enum PaymentProvider {
  BOLD
}

enum PaymentFlow {
  DIRECT_API
  PAYMENT_LINK
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  FAILED
  VOIDED
  EXPIRED
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  INVALID_SIGNATURE
  ERROR
}

enum ShareNetwork {
  WHATSAPP
  FACEBOOK
  TWITTER
  LINKEDIN
  COPY_LINK
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  password    String
  name        String?
  role        Role         @default(CLIENTE)
  isActive    Boolean      @default(true)
  orders      Order[]
  posts       Post[]
  shareEvents ShareEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   @db.LongText
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id           String        @id @default(cuid())
  name         String
  description  String        @db.LongText 
  price        Decimal       @db.Decimal(10, 2)
  stock        Int           @default(0)
  sku          String        @unique
  status       ProductStatus @default(DRAFT)
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  variants     ProductVariant[]
  orderItems   OrderItem[]
  tags         Tag[]         @relation("ProductTags")
  shareEvents  ShareEvent[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  isMain    Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String   @unique
  size      String?
  color     String?
  stoneType String?
  stock     Int      @default(0)
  price     Float?

  @@index([productId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  imageUrl  String?
  createdAt DateTime  @default(now())
  products  Product[] @relation("ProductTags")
}

model Order {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  status          PaymentStatus     @default(PENDING)
  totalAmount     Decimal           @db.Decimal(10, 2)
  shippingAddress String            @db.LongText
  shippingMode    ShippingMode      @default(FIXED)
  shippingCost    Decimal           @db.Decimal(10, 2)
  paymentProvider PaymentProvider   @default(BOLD)
  paymentFlow     PaymentFlow       @default(PAYMENT_LINK)
  paymentUrl      String?           @db.Text
  transactionId   String?           @unique
  items           OrderItem[]
  webhookLogs     WebhookEventLog[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

model PageLayout {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  blocks    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.LongText
  image     String?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model System_Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String  @db.LongText
  description String? @db.LongText
  updatedAt   DateTime @updatedAt
}

model ShareEvent {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  network     ShareNetwork
  adminUserId String?
  adminUser   User?        @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())

  @@index([productId, createdAt])
  @@index([network, createdAt])
}

model WebhookEventLog {
  id               String                  @id @default(cuid())
  provider         PaymentProvider         @default(BOLD)
  eventId          String?
  eventType        String
  subject          String?
  idempotencyKey   String                  @unique
  orderId          String?
  order            Order?                  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  signature        String?
  processingStatus WebhookProcessingStatus @default(RECEIVED)
  payload          Json
  errorMessage     String?
  receivedAt       DateTime                @default(now())
  processedAt      DateTime?

  @@index([provider, receivedAt])
  @@index([orderId])
}

